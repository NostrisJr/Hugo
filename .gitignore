# Rust
/target
**/*.rs.bk
Cargo.lock.orig

# Données compilées (générées par tools/, non versionnées)
*.fst
*.dawg
# … sauf les assets embarqués par hugo-core (POC)
!crates/hugo-core/assets/*.fst

# Sources de données brutes (à télécharger, non redistribuées)
/data

# Artefacts d'intégration
/crates/hugo-wasm/pkg
*.xcframework
# Le header C (crates/hugo-ffi/include/hugo.h) est versionné : il sert de
# référence d'API et se régénère avec cbindgen (voir crates/hugo-ffi/cbindgen.toml).

# Claude Code (artefacts locaux, non versionnés)
/.claude
/memory

# OS / éditeurs
.DS_Store
*.swp
.idea/
.vscode/
